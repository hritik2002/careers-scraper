{
  "name": "careers-scraper",
  "version": "1.0.0",
  "description": "Scrape career pages, match jobs to your resume, and email high-fit opportunities",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "scrape": "node src/index.js --dry-run",
    "check-coverage": "node src/check-coverage.js",
    "resolve-pages": "node scripts/add-vc-portfolio.js",
    "generate-companies-md": "node scripts/generate-companies-md.js",
    "probe-startup-ats": "node scripts/probe-startup-ats.js",
    "add-vc-portfolio": "node scripts/add-vc-portfolio.js",
    "validate-scrape-targets": "node scripts/validate-scrape-targets.js",
    "fix-known-ats": "node scripts/fix-known-ats-urls.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0"
  }
}
